<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1150.0" styleClass="main-container" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <left>
        <VBox prefWidth="260.0" spacing="15.0" styleClass="sidebar">
            <padding>
                <Insets bottom="30.0" left="30.0" right="20.0" top="40.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="2.0">
                <VBox.margin>
                    <Insets bottom="30.0" />
                </VBox.margin>
                <Label text="Tech" styleClass="logo-text-primary" />
                <Label text="Portal" styleClass="logo-text-accent" />
            </HBox>

            <Label text="❖  Overview" styleClass="nav-link-active" />
            <Label text="▤  System Logs" styleClass="nav-link" />
            <Label text="🕮  Documentation" styleClass="nav-link" />
            <Label text="⚙  Settings" styleClass="nav-link" />

            <Region VBox.vgrow="ALWAYS" />

            <Label text="MerStats" styleClass="merstats-label" />
            <Label text="SysAdmin Level 4" styleClass="merstats-subtitle" />
        </VBox>
    </left>

    <center>
        <StackPane styleClass="center-background">
            <padding>
                <Insets bottom="50.0" left="60.0" right="60.0" top="50.0" />
            </padding>

            <VBox alignment="CENTER" spacing="25.0" styleClass="content-card">
                <padding>
                    <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
                </padding>

                <Label text="✦" styleClass="illustration-placeholder" />

                <VBox alignment="CENTER" spacing="5.0">
                    <Label text="Ready to Query" styleClass="hero-header" />
                    <Label text="Enter a unique Team ID to retrieve real-time telemetry and advanced analytics." styleClass="hero-subtitle" wrapText="true" />
                </VBox>

                <HBox alignment="CENTER" styleClass="center-search-wrapper">
                    <VBox.margin>
                        <Insets top="20.0" bottom="10.0"/>
                    </VBox.margin>
                    <TextField prefWidth="450.0" promptText="Search Team ID... (Ctrl + K)" styleClass="center-search-input" />
                    <Button mnemonicParsing="false" styleClass="center-search-button" text="Search" />
                </HBox>

                <VBox alignment="CENTER" spacing="15.0">
                    <Label text="RECENT QUERIES" styleClass="section-label" />
                    <HBox alignment="CENTER" spacing="15.0">
                        <Button mnemonicParsing="false" styleClass="chip-button" text="Team Alpha-7" />
                        <Button mnemonicParsing="false" styleClass="chip-button" text="Node Beta-9" />
                        <Button mnemonicParsing="false" styleClass="chip-button" text="Sys ID: 00482" />
                    </HBox>
                </VBox>

            </VBox>
        </StackPane>
    </center>

</BorderPane>